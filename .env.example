# ── rust-e2e-chat-api — environment variables ─────────────────────────────────
#
# Copy to .env and fill in values before running docker compose.
#
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=chatuser
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=chatdb

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password

# ── Admin API ─────────────────────────────────────────────────────────────────
# Secret token for the /admin/* routes. Generate with: openssl rand -hex 32
ADMIN_TOKEN=change-me-admin-token

# ── API ports ─────────────────────────────────────────────────────────────────
API_PORT=8080
CLIENT_PORT=3000

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Production OIDC setup ─────────────────────────────────────────────────────
#
# After starting the stack, register your OIDC provider as a tenant:
#
#   curl -X POST http://localhost:8080/admin/tenants \
#     -H "Authorization: Bearer $ADMIN_TOKEN" \
#     -H "Content-Type: application/json" \
#     -d '{"name":"My App","oidc_issuer":"https://your-idp.example.com"}'
#
# The API validates JWTs against {oidc_issuer}/.well-known/jwks.json
# (standard OpenID Connect discovery path).
#
# Supported providers (any standard OIDC provider works):
#   - Auth0:      https://{your-domain}.auth0.com
#   - Keycloak:   https://keycloak.example.com/realms/{realm}
#   - Okta:       https://{your-domain}.okta.com
#   - Cognito:    https://cognito-idp.{region}.amazonaws.com/{pool-id}
#   - Firebase:   https://securetoken.google.com/{project-id}
#   - Supabase:   https://{project-ref}.supabase.co/auth/v1
#
# Multiple tenants with different providers are supported simultaneously.
#
# ── Dev / Preview OIDC (mock-oauth2-server) ───────────────────────────────────
#
# For local development, use the dev overlay instead of a real provider:
#
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d
#
# Then register the dev tenant:
#   curl -X POST http://localhost:3000/admin/tenants \
#     -H "Authorization: Bearer $ADMIN_TOKEN" \
#     -H "Content-Type: application/json" \
#     -d '{"name":"Dev Tenant","oidc_issuer":"http://oidc/default"}'
#
# Issue tokens for any user:
#   curl -X POST http://localhost:3000/oidc/default/token \
#     -H "Content-Type: application/x-www-form-urlencoded" \
#     -d "grant_type=client_credentials&client_id=alice&client_secret=any"
